---
const currentYear = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <p>&copy; {currentYear} placebookmarks.com - App Development Technical Vocabulary Resource</p>
  </div>
</footer>

<style>
  .site-footer {
    background: #f5f5f5;
    border-top: 1px solid #e5e5e5;
    padding: 20px 0;
    margin-top: 60px;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: center;
  }
  p {
    margin: 0;
    color: #666;
    font-size: 0.9rem;
  }
</style>
