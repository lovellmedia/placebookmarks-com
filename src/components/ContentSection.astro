---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<section class="content-section">
  {title && <h1>{title}</h1>}
  <div class="content">
    <slot />
  </div>
</section>

<style>
  .content-section {
    background: #fff;
    padding: 30px;
    border-radius: 8px;
    border: 1px solid #e5e5e5;
  }
  h1 {
    font-size: 2rem;
    margin-bottom: 24px;
    color: #333;
    line-height: 1.3;
  }
  .content {
    font-size: 1rem;
    line-height: 1.8;
    color: #444;
  }
  .content :global(h2) {
    font-size: 1.4rem;
    margin-top: 32px;
    margin-bottom: 16px;
    color: #333;
    border-bottom: 1px solid #e5e5e5;
    padding-bottom: 8px;
  }
  .content :global(h3) {
    font-size: 1.15rem;
    margin-top: 24px;
    margin-bottom: 12px;
    color: #444;
  }
  .content :global(p) {
    margin-bottom: 16px;
  }
  .content :global(ul), .content :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
  }
  .content :global(li) {
    margin-bottom: 8px;
  }
  .content :global(a) {
    color: #667eea;
    text-decoration: none;
  }
  .content :global(a:hover) {
    text-decoration: underline;
  }
  .content :global(blockquote) {
    border-left: 4px solid #667eea;
    margin: 20px 0;
    padding: 10px 20px;
    background: #f8f9ff;
    font-style: italic;
  }
  @media (max-width: 768px) {
    .content-section {
      padding: 20px;
    }
    h1 {
      font-size: 1.6rem;
    }
  }
</style>
