---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'PlaceBookmarks - App Development Technical Vocabulary';
const description = 'Comprehensive technical vocabulary resource for app development professionals, covering mobile development concepts, frameworks, and terminology.';
---

<BaseLayout title={title} description={description}>
  <div class="homepage">
    <section class="hero">
      <h1>App Development Technical Vocabulary</h1>
      <p class="tagline">Master the terminology, frameworks, and concepts essential for modern application development</p>
    </section>

    <section class="topics-section">
      <h2>Featured Topic</h2>
      <div class="topic-card">
        <h3><a href="/mobile-app-development/">Mobile App Development</a></h3>
        <p>Explore the comprehensive technical vocabulary, frameworks, and methodologies used in modern mobile application development for iOS and Android platforms.</p>
        <div class="pillar-links">
          <a href="/mobile-app-development/">Overview</a>
          <a href="/mobile-app-development/history/">History</a>
          <a href="/mobile-app-development/technical-deep-dive/">Technical</a>
          <a href="/mobile-app-development/ontology/">Ontology</a>
          <a href="/mobile-app-development/trends/">Trends</a>
          <a href="/mobile-app-development/tools/">Tools</a>
          <a href="/mobile-app-development/challenges/">Challenges</a>
        </div>
      </div>
    </section>

    <section class="about-section">
      <h2>About PlaceBookmarks</h2>
      <p>PlaceBookmarks is a specialized technical vocabulary resource designed for app developers, software engineers, and technology professionals. Our comprehensive guides cover the terminology, concepts, and frameworks essential for building modern applications across multiple platforms.</p>
      <p>Each topic includes detailed explanations, historical context, technical deep-dives, and practical resources to help you master the language of app development.</p>
    </section>
  </div>
</BaseLayout>

<style>
  .homepage {
    max-width: 100%;
  }
  .hero {
    text-align: center;
    padding: 60px 20px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: #fff;
    border-radius: 12px;
    margin-bottom: 40px;
  }
  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 16px;
    color: #fff;
  }
  .tagline {
    font-size: 1.2rem;
    opacity: 0.95;
    max-width: 600px;
    margin: 0 auto;
  }
  .topics-section {
    margin-bottom: 40px;
  }
  .topics-section h2 {
    font-size: 1.8rem;
    margin-bottom: 24px;
    color: #333;
  }
  .topic-card {
    background: #fff;
    padding: 30px;
    border-radius: 8px;
    border: 1px solid #e5e5e5;
  }
  .topic-card h3 {
    font-size: 1.4rem;
    margin-bottom: 12px;
  }
  .topic-card h3 a {
    color: #667eea;
    text-decoration: none;
  }
  .topic-card h3 a:hover {
    text-decoration: underline;
  }
  .topic-card > p {
    color: #555;
    margin-bottom: 20px;
    line-height: 1.6;
  }
  .pillar-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .pillar-links a {
    padding: 8px 16px;
    background: #f0f0f0;
    color: #333;
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s;
  }
  .pillar-links a:hover {
    background: #667eea;
    color: #fff;
  }
  .about-section {
    background: #fff;
    padding: 30px;
    border-radius: 8px;
    border: 1px solid #e5e5e5;
  }
  .about-section h2 {
    font-size: 1.5rem;
    margin-bottom: 16px;
    color: #333;
  }
  .about-section p {
    color: #555;
    line-height: 1.7;
    margin-bottom: 12px;
  }
  @media (max-width: 768px) {
    .hero {
      padding: 40px 20px;
    }
    .hero h1 {
      font-size: 1.8rem;
    }
    .tagline {
      font-size: 1rem;
    }
  }
</style>
